---
import { getCollection } from "astro:content";
import { Calendar, Camera, Clock, Network, PlayCircle, Search, User } from "lucide-react";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [mainPost, ...secondaryPosts] = posts;
const heroSidePosts = secondaryPosts.slice(0, 2);
const topStories = posts.slice(3, 7);
const latestPosts = posts.slice(7);

const categoryColors: Record<string, string> = {
  Tech: "bg-cyan-400 text-slate-950",
  Lifestyle: "bg-rose-500 text-white",
  Cultura: "bg-violet-500 text-white",
  Negocios: "bg-amber-400 text-slate-950",
  Design: "bg-emerald-400 text-slate-950",
};

const getCategoryClass = (category: string) =>
  categoryColors[category] ?? "bg-slate-100 text-slate-950";

function calculateReadingTime(body: string | undefined): string {
  const words = body?.trim().split(/\s+/).filter(Boolean).length ?? 0;
  return `${Math.max(1, Math.ceil(words / 200))} min`;
}
---

<BaseLayout
  title="Blogar Style | Revista digital moderna"
  description="Portal de notícias e revista digital em Astro, Tailwind CSS e Content Collections."
>
  <header class="sticky top-0 z-50 border-b border-white/10 bg-background/70 backdrop-blur-xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
      <a href="/" class="text-xl font-black tracking-tight text-white">
        Blogar<span class="text-primary">Style</span>
      </a>

      <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-300 md:flex">
        <a href="#top-stories" class="hover:text-primary">Top Stories</a>
        <a href="#latest" class="hover:text-primary">Últimas</a>
        <a href="#newsletter" class="hover:text-primary">Newsletter</a>
      </nav>

      <div class="flex items-center gap-3">
        <label class="hidden items-center rounded-full border border-white/10 bg-white/5 px-3 py-2 sm:flex">
          <span class="sr-only">Buscar</span>
          <Search className="h-4 w-4 text-slate-400" aria-hidden="true" />
          <input
            type="search"
            placeholder="Buscar..."
            class="w-28 bg-transparent px-2 text-sm text-white outline-none placeholder:text-slate-500 lg:w-44"
          />
        </label>
        <div class="hidden items-center gap-2 text-slate-300 sm:flex">
          <a href="#" aria-label="Instagram" class="rounded-full p-2 hover:bg-white/10">
            <Camera className="h-4 w-4 text-slate-400" aria-hidden="true" />
          </a>
          <a href="#" aria-label="YouTube" class="rounded-full p-2 hover:bg-white/10">
            <PlayCircle className="h-4 w-4 text-slate-400" aria-hidden="true" />
          </a>
          <a href="#" aria-label="LinkedIn" class="rounded-full p-2 hover:bg-white/10">
            <Network className="h-4 w-4 text-slate-400" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </header>

  <main>
    <section class="mx-auto max-w-7xl px-4 pb-12 pt-8 sm:px-6 lg:px-8 lg:pt-12">
      <div class="mb-8 max-w-3xl">
        <p class="mb-3 text-sm font-bold uppercase tracking-[0.3em] text-primary">Revista digital</p>
        <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-7xl">
          Notícias, tendências e cultura para leitores modernos.
        </h1>
      </div>

      {
        mainPost && (
          <div class="grid gap-5 lg:grid-cols-[1.55fr_1fr]">
            <a
              href={`/blog/${mainPost.slug}`}
              class="group relative min-h-[520px] overflow-hidden rounded-3xl bg-card shadow-2xl shadow-black/30"
            >
              <img
                src={mainPost.data.image}
                alt={mainPost.data.title}
                class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-x-0 bottom-0 h-3/4 bg-gradient-to-t from-black via-black/70 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
                <span class={`mb-4 inline-flex rounded-full px-3 py-1 text-xs font-black uppercase tracking-wide ${getCategoryClass(mainPost.data.category)}`}>
                  {mainPost.data.category}
                </span>
                <h2 class="max-w-2xl text-3xl font-black leading-tight text-white sm:text-5xl">
                  {mainPost.data.title}
                </h2>
                <p class="mt-4 max-w-2xl text-base text-slate-200">{mainPost.data.description}</p>
                <div class="mt-5 flex flex-wrap items-center gap-4 text-xs font-medium text-slate-300">
                  <span class="inline-flex items-center gap-1.5">
                    <User className="h-4 w-4 text-slate-400" aria-hidden="true" />
                    {mainPost.data.author}
                  </span>
                  <span class="inline-flex items-center gap-1.5">
                    <Calendar className="h-4 w-4 text-slate-400" aria-hidden="true" />
                    {mainPost.data.pubDate.toLocaleDateString("pt-BR")}
                  </span>
                  <span class="inline-flex items-center gap-1.5">
                    <Clock className="h-4 w-4 text-slate-400" aria-hidden="true" />
                    {calculateReadingTime(mainPost.body)}
                  </span>
                </div>
              </div>
            </a>

            <div class="grid gap-5">
              {heroSidePosts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="group relative min-h-[250px] overflow-hidden rounded-3xl bg-card shadow-xl shadow-black/20"
                >
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-3/4 bg-gradient-to-t from-black via-black/70 to-transparent"></div>
                  <div class="absolute inset-x-0 bottom-0 p-6">
                    <span class={`mb-3 inline-flex rounded-full px-3 py-1 text-[11px] font-black uppercase tracking-wide ${getCategoryClass(post.data.category)}`}>
                      {post.data.category}
                    </span>
                    <h3 class="text-2xl font-black leading-tight text-white">{post.data.title}</h3>
                    <div class="mt-3 flex items-center gap-3 text-xs text-slate-300">
                      <span class="inline-flex items-center gap-1.5">
                        <Calendar className="h-4 w-4 text-slate-400" aria-hidden="true" />
                        {post.data.pubDate.toLocaleDateString("pt-BR")}
                      </span>
                      <span class="inline-flex items-center gap-1.5">
                        <Clock className="h-4 w-4 text-slate-400" aria-hidden="true" />
                        {calculateReadingTime(post.body)}
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </section>

    <section id="top-stories" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.3em] text-accent">Em destaque</p>
          <h2 class="mt-2 text-3xl font-black text-white">Top Stories</h2>
        </div>
        <a href="#latest" class="rounded-full bg-primary px-5 py-2 text-sm font-black text-slate-950 hover:opacity-90">
          Ver tudo
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {topStories.map((post) => (
          <article class="group overflow-hidden rounded-2xl bg-card shadow-lg shadow-black/20">
            <a href={`/blog/${post.slug}`} class="relative block overflow-hidden">
              <img
                src={post.data.image}
                alt={post.data.title}
                class="h-52 w-full object-cover transition duration-700 group-hover:scale-110"
              />
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/90 via-black/45 to-transparent"></div>
            </a>
            <div class="p-5">
              <span class={`mb-3 inline-flex rounded-full px-3 py-1 text-[11px] font-black uppercase tracking-wide ${getCategoryClass(post.data.category)}`}>
                {post.data.category}
              </span>
              <h3 class="text-xl font-black leading-tight text-white">
                <a href={`/blog/${post.slug}`} class="hover:text-primary">{post.data.title}</a>
              </h3>
              <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-slate-400">
                <span class="inline-flex items-center gap-1.5">
                  <User className="h-4 w-4" aria-hidden="true" />
                  {post.data.author}
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <Clock className="h-4 w-4" aria-hidden="true" />
                  {calculateReadingTime(post.body)}
                </span>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-400">{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="latest" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post) => (
          <article class="rounded-2xl border border-white/10 bg-card p-5 shadow-lg shadow-black/10">
            <span class={`mb-3 inline-flex rounded-full px-3 py-1 text-[11px] font-black uppercase tracking-wide ${getCategoryClass(post.data.category)}`}>
              {post.data.category}
            </span>
            <h3 class="text-2xl font-black text-white">
              <a href={`/blog/${post.slug}`} class="hover:text-primary">{post.data.title}</a>
            </h3>
            <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-slate-400">
              <span class="inline-flex items-center gap-1.5">
                <Calendar className="h-4 w-4" aria-hidden="true" />
                {post.data.pubDate.toLocaleDateString("pt-BR")}
              </span>
              <span class="inline-flex items-center gap-1.5">
                <Clock className="h-4 w-4" aria-hidden="true" />
                {calculateReadingTime(post.body)}
              </span>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-400">{post.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer id="newsletter" class="border-t border-white/10 bg-black/20">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-2 lg:grid-cols-4 lg:px-8">
      <div>
        <h2 class="text-2xl font-black">Blogar<span class="text-primary">Style</span></h2>
        <p class="mt-3 text-sm leading-6 text-slate-400">Um template de revista digital em Astro e Tailwind CSS.</p>
      </div>
      <div>
        <h3 class="font-bold text-white">Editorias</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-400">
          <li>Tech</li>
          <li>Lifestyle</li>
          <li>Cultura</li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold text-white">Social</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-400">
          <li class="flex items-center gap-2">
            <Camera className="h-4 w-4 text-slate-400" aria-hidden="true" />
            Instagram
          </li>
          <li class="flex items-center gap-2">
            <PlayCircle className="h-4 w-4 text-slate-400" aria-hidden="true" />
            YouTube
          </li>
          <li class="flex items-center gap-2">
            <Network className="h-4 w-4 text-slate-400" aria-hidden="true" />
            LinkedIn
          </li>
        </ul>
      </div>
      <form class="rounded-2xl bg-card p-5">
        <h3 class="font-bold text-white">Receba a newsletter</h3>
        <p class="mt-2 text-sm text-slate-400">Insights semanais direto no seu e-mail.</p>
        <input
          type="email"
          placeholder="seu@email.com"
          class="mt-4 w-full rounded-xl border border-white/10 bg-black/30 px-4 py-3 text-sm text-white outline-none focus:border-primary"
        />
        <button class="mt-3 w-full rounded-xl bg-accent px-4 py-3 text-sm font-black text-white hover:opacity-90">
          Inscrever
        </button>
      </form>
    </div>
  </footer>
</BaseLayout>
